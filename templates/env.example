# claude-context configuration
# Copy to .env and uncomment/edit as needed.
# .env is gitignored and never committed.

# Cowork working directory (default: ~/CoworkSpace)
# COWORK_DIR=~/CoworkSpace

# Path to a local clone of your skills repo (optional)
# Skills are symlinked to ~/.claude/skills/ on sync
# SKILLS_DIR=~/claude-skills/skills
